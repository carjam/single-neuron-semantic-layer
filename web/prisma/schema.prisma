generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Outcome / workstream (subject option) selected by argmax.
model Rule {
  id             Int             @id @map("rule_id")
  decisionCode   String          @unique @map("decision_code")
  hierarchyRules HierarchyRule[]

  @@map("demo_rules")
}

model Feature {
  id   Int    @id @map("feature_id")
  code String @unique @map("feature_code")

  @@map("demo_features")
}

/// Raw security rows: vendor (ald_*) + optional fund overrides.
model Observation {
  id                      Int     @id @default(autoincrement()) @map("observation_id")
  isin                    String
  aldIssuerClass          String  @map("ald_issuer_class")
  fundIssuerClassOverride String? @map("fund_issuer_class_override")
  aldRegion               String  @map("ald_region")
  fundRegionOverride      String? @map("fund_region_override")
  aldRatingBand           String  @map("ald_rating_band")
  fundRatingBandOverride  String? @map("fund_rating_band_override")

  @@map("demo_observations")
}

/// Wildcard-capable hierarchy rules used for precedence enrichment.
model HierarchyRule {
  id               Int    @id @default(autoincrement()) @map("hierarchy_rule_id")
  ruleId           Int    @map("rule_id")
  hierarchyTop     String @map("hierarchy_top")
  hierarchyMiddle  String @map("hierarchy_middle")
  hierarchyBottom  String @map("hierarchy_bottom")
  descriptor01     String @map("descriptive_value_a")
  descriptor02     String? @map("descriptive_value_b")
  descriptor03     String? @map("descriptive_value_c")
  descriptor04     String? @map("descriptive_value_d")
  descriptor05     String? @map("descriptive_value_e")
  descriptor06     String? @map("descriptive_value_f")
  descriptor07     String? @map("descriptive_value_g")
  descriptor08     String? @map("descriptive_value_h")
  descriptor09     String? @map("descriptive_value_i")
  descriptor10     String? @map("descriptive_value_j")
  rule             Rule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("demo_hierarchy_enrichment_rules")
}
